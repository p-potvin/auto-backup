<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        AutoBackup app-level styles.
        Palette follows VaultWares STYLE.md:
          Dark mode  — base #4A5568 / accent #cc9b21 (gold)
          Light mode — near-white / deep blue sea
    -->

    <!-- Accent colour overrides for dark theme -->
    <SolidColorBrush x:Key="AccentGold" Color="#cc9b21" />
    <SolidColorBrush x:Key="AccentBlue" Color="#2563EB" />

    <!-- Card background — slightly elevated surface -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{ThemeResource LayerFillColorDefaultBrush}" />

    <!-- Subtle button style (used for back / icon-only actions) -->
    <Style x:Key="SubtleButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- Status badge — enabled -->
    <Style x:Key="EnabledBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
    </Style>

    <!-- Status badge — paused -->
    <Style x:Key="PausedBadgeStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
    </Style>

</ResourceDictionary>
