<Page
    x:Class="AutoBackup.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer Padding="24">
        <StackPanel MaxWidth="600" Spacing="24">

            <Button Content="&#xE72B; Back"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource SubtleButtonStyle}"
                    Click="Back_Click"
                    Margin="0,0,0,8" />

            <TextBlock Text="Settings" Style="{StaticResource TitleTextBlockStyle}" />

            <!-- Tray behaviour -->
            <StackPanel Spacing="8">
                <TextBlock Text="Application Behaviour"
                           Style="{StaticResource SubtitleTextBlockStyle}" />

                <CheckBox x:Name="MinimizeToTrayCheck"
                          Content="Minimize to system tray when window is closed" />

                <CheckBox x:Name="StartWithWindowsCheck"
                          Content="Start AutoBackup automatically at Windows login" />
            </StackPanel>

            <!-- Theme -->
            <StackPanel Spacing="8">
                <TextBlock Text="Theme" Style="{StaticResource SubtitleTextBlockStyle}" />
                <ComboBox x:Name="ThemeCombo" MinWidth="200">
                    <ComboBoxItem Content="System default" Tag="" />
                    <ComboBoxItem Content="Light" Tag="Light" />
                    <ComboBoxItem Content="Dark" Tag="Dark" />
                </ComboBox>
            </StackPanel>

            <!-- Log location -->
            <StackPanel Spacing="8">
                <TextBlock Text="Logs" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock x:Name="LogPathText"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <Button Content="Open Log File" Click="OpenLog_Click" />
            </StackPanel>

            <!-- Save button -->
            <Button Content="Save Settings"
                    Style="{StaticResource AccentButtonStyle}"
                    HorizontalAlignment="Left"
                    Click="Save_Click" />

        </StackPanel>
    </ScrollViewer>

</Page>
