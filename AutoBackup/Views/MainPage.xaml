<Page
    x:Class="AutoBackup.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AutoBackup.ViewModels"
    xmlns:views="using:AutoBackup.Views"
    xmlns:converters="using:AutoBackup.Converters"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>

        <!-- ── Title Bar / Toolbar ─────────────────────────────────────────── -->
        <Grid Grid.Row="0" Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="AutoBackup"
                           Style="{StaticResource TitleTextBlockStyle}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button Content="&#xE710; Add Job"
                        FontFamily="Segoe MDL2 Assets"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="AddJob_Click" />
                <Button Content="&#xE713;"
                        FontFamily="Segoe MDL2 Assets"
                        ToolTipService.ToolTip="Settings"
                        Click="Settings_Click" />
            </StackPanel>
        </Grid>

        <!-- ── Jobs List ───────────────────────────────────────────────────── -->
        <Grid Grid.Row="1" Padding="16,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Job List -->
            <Border Grid.Column="0"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <ListView x:Name="JobListView"
                          ItemsSource="{x:Bind ViewModel.Jobs, Mode=OneWay}"
                          SelectedItem="{x:Bind ViewModel.SelectedJob, Mode=TwoWay}"
                          Padding="4">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:BackupJobViewModel">
                            <Grid Padding="8,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind IntervalDisplay, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind LastRunDisplay, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>

                                <Border Grid.Column="1"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                                        Visibility="{x:Bind IsEnabled, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                    <TextBlock Text="ON"
                                               FontSize="10"
                                               Foreground="White" />
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Job Detail Panel -->
            <Border Grid.Column="2"
                    CornerRadius="8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    Padding="20">
                <ScrollViewer>
                    <StackPanel Spacing="16"
                                Visibility="{x:Bind ViewModel.SelectedJob, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">

                        <!-- Job name + action buttons -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.Name, Mode=OneWay}"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="&#xE70F;"
                                        FontFamily="Segoe MDL2 Assets"
                                        ToolTipService.ToolTip="Edit job"
                                        Click="EditJob_Click" />
                                <Button Content="&#xE768;"
                                        FontFamily="Segoe MDL2 Assets"
                                        ToolTipService.ToolTip="Run now"
                                        Click="RunJobNow_Click" />
                                <ToggleButton x:Name="ToggleEnabled"
                                              ToolTipService.ToolTip="Enable / Pause"
                                              IsChecked="{x:Bind ViewModel.SelectedJob.IsEnabled, Mode=OneWay}"
                                              Click="ToggleEnabled_Click">
                                    <TextBlock Text="{x:Bind ViewModel.SelectedJob.StatusBadge, Mode=OneWay}" />
                                </ToggleButton>
                                <Button Content="&#xE74D;"
                                        FontFamily="Segoe MDL2 Assets"
                                        ToolTipService.ToolTip="Remove job"
                                        Click="DeleteJob_Click" />
                            </StackPanel>
                        </Grid>

                        <InfoBar x:Name="JobDetailInfo" IsOpen="False" />

                        <!-- Source -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Source" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.SourcePath, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Destination -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Destination" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.DestinationPath, Mode=OneWay}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- Folder Name Pattern -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Folder Name Pattern" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.FolderNamePattern, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Interval -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Interval" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.IntervalDisplay, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Archive Format -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Archive Format" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.ArchiveFormat, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Blocking Process -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Blocking Process" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.BlockingProcessName, Mode=OneWay}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <!-- Notifications -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Notifications" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.SendNotifications, Mode=OneWay}" />
                        </StackPanel>

                        <!-- Last Run -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Last Run" Style="{StaticResource CaptionTextBlockStyle}" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedJob.LastRunDisplay, Mode=OneWay}" />
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Log Panel ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Margin="16,0,16,12"
                CornerRadius="8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="Log"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Padding="12,8,12,4"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ListView Grid.Row="1"
                          ItemsSource="{x:Bind ViewModel.LogLines, Mode=OneWay}"
                          Padding="8,0,8,8"
                          SelectionMode="None"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="x:String">
                            <TextBlock Text="{x:Bind}"
                                       FontFamily="Cascadia Code, Consolas, monospace"
                                       FontSize="11"
                                       TextWrapping="NoWrap" />
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>

</Page>
