<ContentDialog
    x:Class="AutoBackup.Views.Dialogs.AddEditJobDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:AutoBackup.ViewModels"
    xmlns:models="using:AutoBackup.Models"
    xmlns:converters="using:AutoBackup.Converters"
    Title="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource EditTitleConverter}}"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{x:Bind ViewModel.CanSave, Mode=OneWay}"
    MinWidth="520">

    <ContentDialog.Resources>
        <converters:EditTitleConverter x:Key="EditTitleConverter" />
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16" Padding="0,8,0,0">

            <!-- Job Name -->
            <StackPanel Spacing="4">
                <TextBlock Text="Job Name" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox Text="{x:Bind ViewModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="e.g., Documents Backup" />
            </StackPanel>

            <!-- Source Path -->
            <StackPanel Spacing="4">
                <TextBlock Text="Source Folder" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.SourcePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="C:\Users\you\Documents" />
                    <Button Grid.Column="1" Content="&#xE8DA;" FontFamily="Segoe MDL2 Assets"
                            ToolTipService.ToolTip="Browse…" Click="BrowseSource_Click" />
                </Grid>
            </StackPanel>

            <!-- Destination Path -->
            <StackPanel Spacing="4">
                <TextBlock Text="Destination Folder" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Text="{x:Bind ViewModel.DestinationPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             PlaceholderText="D:\Backups" />
                    <Button Grid.Column="1" Content="&#xE8DA;" FontFamily="Segoe MDL2 Assets"
                            ToolTipService.ToolTip="Browse…" Click="BrowseDest_Click" />
                </Grid>
            </StackPanel>

            <!-- Folder Name Pattern -->
            <StackPanel Spacing="4">
                <TextBlock Text="Destination Folder Name Pattern"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Use {yyyy}, {MM}, {dd}, {HH}, {mm} tokens for dynamic names."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBox Text="{x:Bind ViewModel.FolderNamePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="backup-{yyyy-MM-dd}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Preview:"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{x:Bind ViewModel.FolderNamePreview, Mode=OneWay}"
                               Style="{StaticResource CaptionTextBlockStyle}"
                               FontWeight="SemiBold" />
                </StackPanel>
            </StackPanel>

            <!-- Backup Interval -->
            <StackPanel Spacing="4">
                <TextBlock Text="Backup Interval" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox ItemsSource="{x:Bind ViewModel.IntervalOptions}"
                          SelectedItem="{x:Bind ViewModel.IntervalMinutes, Mode=TwoWay}"
                          MinWidth="200">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="x:Int32">
                            <TextBlock Text="{x:Bind}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <TextBlock Text="(minutes)"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Archive Format -->
            <StackPanel Spacing="4">
                <TextBlock Text="Archive Format" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ComboBox ItemsSource="{x:Bind ViewModel.ArchiveOptions}"
                          SelectedItem="{x:Bind ViewModel.ArchiveFormat, Mode=TwoWay}"
                          MinWidth="200" />
            </StackPanel>

            <!-- Blocking Process -->
            <StackPanel Spacing="4">
                <TextBlock Text="Skip Backup While App Is Running"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock Text="Enter a process name (e.g., outlook.exe) to prevent backup while it runs."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           TextWrapping="Wrap" />
                <TextBox Text="{x:Bind ViewModel.BlockingProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         PlaceholderText="outlook.exe  (optional)" />
            </StackPanel>

            <!-- Notifications -->
            <CheckBox Content="Send Windows notification on completion or error"
                      IsChecked="{x:Bind ViewModel.SendNotifications, Mode=TwoWay}" />

        </StackPanel>
    </ScrollViewer>

</ContentDialog>
